# copy to .env and tweak — these defaults are for local only

DATABASE_URL=postgresql://codearena:codearena@localhost:5432/codearena?schema=public
REDIS_URL=redis://localhost:6379

# change these before any real deploy
JWT_ACCESS_SECRET=local-dev-access-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# mock = tests only | docker = local containers | judge0 = real runs
EXECUTOR_MODE=judge0
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_API_KEY=
ALLOW_MOCK_EXECUTOR=false
ALLOW_MOCK_EXECUTOR_IN_PRODUCTION=false

DOCKER_MEMORY_LIMIT=256m
DOCKER_TIME_LIMIT=2

# testcase generation limits (admin feature)
MAX_GENERATED_CASES_PER_JOB=100
MAX_GENERATED_INPUT_BYTES=65536
MAX_GENERATED_OUTPUT_BYTES=65536
MAX_GENERATION_JOB_RUNTIME_MS=120000

# frontend
VITE_API_URL=http://localhost:4000/api/v1
